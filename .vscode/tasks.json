{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "package-cs2stats-release",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/package-release.ps1"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build-release-with-package",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "src/CS2Stats.Plugin/CS2Stats.Plugin.csproj",
        "-c",
        "Release"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ]
    }
  ]
}